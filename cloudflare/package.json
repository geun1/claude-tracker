{
  "name": "claude-tracker-worker",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --persist-to .wrangler/state",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:create": "wrangler d1 create claude-tracker",
    "db:migrate": "wrangler d1 migrations apply claude-tracker --remote",
    "db:migrate:local": "wrangler d1 migrations apply claude-tracker --local",
    "r2:create": "wrangler r2 bucket create claude-tracker-blobs"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.85.0"
  }
}
